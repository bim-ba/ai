{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"${CLAUDE_PLUGIN_ROOT}/hooks/behaviour_protocol.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "uv run --no-project python \"${CLAUDE_PLUGIN_ROOT}/hooks/surface_open_drift.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"${CLAUDE_PLUGIN_ROOT}/hooks/drift_log_check.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
